---
import BarcodeC from "./Barcode.astro";
import type { Session } from "../data/sessions";
import signatureSvg from "../assets/image/signature-svgrepo-com.svg?raw";

interface Props {
  session: Session;
}

const { session } = Astro.props;

type RowKey = keyof Pick<Session, "branch" | "hash"> | "record" | "contents";
type SpecRow = {
  key: RowKey;
  value: string;
  accent: string;
  span: "full" | "cell";
};

const specRows: SpecRow[] = [
  {
    key: "contents",
    value: session.topics.join(" / "),
    accent: "accent-cyan",
    span: "full"
  },
  {
    key: "branch",
    value: session.branch,
    accent: "accent-green",
    span: "cell"
  },
  {
    key: "hash",
    value: session.hash,
    accent: "accent-amber",
    span: "cell"
  },
  {
    key: "record",
    value: String(session.record).padStart(2, "0"),
    accent: "accent-violet",
    span: "cell"
  }
];
---

<section class="label-panel">
  <span class="corner tl" aria-hidden="true"></span>
  <span class="corner tr" aria-hidden="true"></span>
  <span class="corner bl" aria-hidden="true"></span>
  <span class="corner br" aria-hidden="true"></span>

  <div class="lead">
    <h1 class="title">
      <span class="title-icon" aria-hidden="true" set:html={signatureSvg} />
      {session.title}
    </h1>
    <p class="summary">{session.summary}</p>
  </div>

  <div class="sheet">
    <div class="spec-grid">
      {
        specRows.map((row) => (
          <article class={row.span === "full" ? "is-contents" : undefined}>
            <span class={`label-tag mono ${row.accent}`}>{row.key}</span>
            <strong class="mono data">{row.value}</strong>
          </article>
        ))
      }
    </div>
  </div>

  <div class="barcode-strip" aria-hidden="true">
    <BarcodeC
      value={session.hash}
      height={44}
      color="#0c2e25"
      label={`${session.hash} · ${session.date}`}
      vertical
    />
  </div>
</section>

<style>
  /* === shared utility classes (spine 也命中) ============== */
  :global(.eyebrow) {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--spine-text);
  }

  :global(.label-tag) {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    padding: 2px 4px;
    line-height: 1.4;
  }

  :global(.accent-green) {
    background: #2ecc40;
    color: #07150a;
  }
  :global(.accent-cyan) {
    background: #00d7ff;
    color: #061015;
  }
  :global(.accent-amber) {
    background: #ffb000;
    color: #140d00;
  }
  :global(.accent-violet) {
    background: #af5eff;
    color: #100516;
  }

  /* === label-panel (scoped) =============================== */
  .label-panel {
    position: relative;
    isolation: isolate;
    padding: clamp(24px, 3vw, 40px);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: clamp(16px, 3vw, 32px);
    border: 1px solid var(--line);
    background: var(--bg);
  }

  /* corner cut marks (printing trim guides) */
  .corner {
    position: absolute;
    z-index: 1;
    width: 10px;
    height: 10px;
    border: 1px solid var(--text-mute);
    pointer-events: none;
  }
  .corner.tl {
    top: -1px;
    left: -1px;
    border-right: none;
    border-bottom: none;
  }
  .corner.tr {
    top: -1px;
    right: -1px;
    border-left: none;
    border-bottom: none;
  }
  .corner.bl {
    bottom: -1px;
    left: -1px;
    border-right: none;
    border-top: none;
  }
  .corner.br {
    bottom: -1px;
    right: -1px;
    border-left: none;
    border-top: none;
  }

  .data {
    font-size: 0.9rem;
  }

  .lead h1 {
    margin: 14px 0 0;
    font-family: var(--font-cn);
    font-weight: 800;
    font-size: clamp(2rem, 5.4vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    max-width: 16ch;
  }

  /* batch sticker: eyebrow "贴" 在 panel 上沿 */
  .lead > .label-tag {
    position: relative;
    top: -10px;
    padding: 4px 10px;
    border: 1px solid var(--line);
    background: var(--bg);
  }

  .title {
    position: relative;
    font-family: var(--font-cn);
    font-weight: 800;
    font-size: clamp(2rem, 5.4vw, 3.6rem);
    line-height: 1.05;
    color: var(--text);
  }

  .title-icon {
    position: absolute;
    bottom: -24px;
    left: -24px;
    width: 72px;
    height: 72px;
    z-index: -1;
    color: magenta;
  }

  .title-icon :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .title-icon :global(path) {
    stroke: magenta;
  }

  .summary {
    max-width: 52ch;
    margin: 18px 0 0;
    font-family: var(--font-cn);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-dim);
  }

  .lead {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .sheet {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-content: start;
    height: auto;
  }

  .barcode-strip {
    position: absolute;
    z-index: 0;
    top: clamp(24px, 3vw, 40px);
    right: 0;
    width: clamp(15px, 2.5vw, 36px);
    pointer-events: none;
    overflow: hidden;
  }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .spec-grid article {
    position: relative;
    z-index: 1;
    padding: 12px 9px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.025);
  }

  .spec-grid article.is-contents {
    grid-column: 1 / -1;
  }

  .spec-grid article > span {
    display: block;
    margin-bottom: 6px;
  }

  .spec-grid article strong {
    display: block;
    font-weight: 700;
    line-height: 1.5;
    color: var(--text);
    word-break: break-all;
  }

  .caption {
    margin: 0;
    font-family: var(--font-cn);
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--text-dim);
  }

  /* === responsive ========================================= */
  @media (max-width: 1079px) {
    .label-panel {
      width: 100%;
      grid-template-columns: 1fr;
      padding: 20px 16px 40px;
    }
  }

  @media (max-width: 640px) {
    .lead h1 {
      font-size: clamp(1.7rem, 9vw, 2.4rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(*) {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
