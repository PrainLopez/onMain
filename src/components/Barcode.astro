---
import { encodeCode128B } from "../lib/code128b";

interface Props {
  value: string;
  height?: number;
  moduleWidth?: number;
  color?: string;
  showText?: boolean;
  label?: string;
  vertical?: boolean;
}

const {
  value,
  height = 44,
  moduleWidth = 1.6,
  color = "currentColor",
  showText,
  label,
  vertical = false
} = Astro.props;

void showText;
void label;

const QUIET_ZONE_MODULES = 2;
const moduleStream = encodeCode128B(value);
const totalModules = moduleStream.length + 2 * QUIET_ZONE_MODULES;
const totalWidth = totalModules * moduleWidth;
const leftOffset = QUIET_ZONE_MODULES * moduleWidth;
---

<svg
  class={`barcode-svg ${vertical ? "vertical" : ""}`}
  role="img"
  aria-label={`barcode of ${value}`}
  viewBox={vertical
    ? `0 0 ${height} ${totalWidth}`
    : `0 0 ${totalWidth} ${height}`}
  preserveAspectRatio="none"
  xmlns="http://www.w3.org/2000/svg"
>
  {
    vertical ? (
      <g transform={`translate(0,${totalWidth}) rotate(-90)`}>
        {[...moduleStream].map((bit, i) =>
          bit === "1" ? (
            <rect
              x={leftOffset + i * moduleWidth}
              y="0"
              width={moduleWidth}
              height={height}
              fill={color}
            />
          ) : null
        )}
      </g>
    ) : (
      [...moduleStream].map((bit, i) =>
        bit === "1" ? (
          <rect
            x={leftOffset + i * moduleWidth}
            y="0"
            width={moduleWidth}
            height={height}
            fill={color}
          />
        ) : null
      )
    )
  }
</svg>

<style>
  .barcode-svg {
    display: block;
    width: 100%;
    height: 44px;
  }
  .barcode-svg.vertical {
    width: 44px;
    height: auto;
  }
</style>
