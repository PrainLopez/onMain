---
interface Props {
	currentKey: string;
	currentLabel: string;
	prevHref: string;
	prevLabel: string;
	nextHref: string;
	nextLabel: string;
}

const { currentKey, currentLabel, prevHref, prevLabel, nextHref, nextLabel } = Astro.props;
---

{!import.meta.env.PROD && (
	<>
		<nav class="prototype-nav" aria-label="Prototype navigation">
			<a class="prototype-nav__arrow" href={prevHref} aria-label={`Previous prototype: ${prevLabel}`}>←</a>
			<a class="prototype-nav__label" href="/indexes" aria-label="Open prototype index">
				<strong>{currentKey}</strong>
				<span>{currentLabel}</span>
			</a>
			<a class="prototype-nav__arrow" href={nextHref} aria-label={`Next prototype: ${nextLabel}`}>→</a>
		</nav>
		<script define:vars={{ prevHref, nextHref }}>
			const isEditable = (target) => {
				if (!(target instanceof HTMLElement)) return false;
				return target.matches('input, textarea, [contenteditable="true"], [contenteditable=""]') || target.isContentEditable;
			};

			window.addEventListener('keydown', (event) => {
				if (isEditable(event.target)) return;
				if (event.key === 'ArrowLeft') window.location.assign(prevHref);
				if (event.key === 'ArrowRight') window.location.assign(nextHref);
			});
		</script>
	</>
)}

<style>
	.prototype-nav {
		position: fixed;
		left: 50%;
		bottom: 20px;
		z-index: 60;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		width: min(720px, calc(100% - 24px));
		padding: 10px 12px;
		border: 1px solid rgba(124, 232, 194, 0.22);
		border-radius: 999px;
		background: rgba(3, 8, 12, 0.9);
		backdrop-filter: blur(18px);
		box-shadow: 0 18px 60px rgba(0, 0, 0, 0.45);
		transform: translateX(-50%);
	}

	.prototype-nav__arrow,
	.prototype-nav__label {
		text-decoration: none;
		color: #effff8;
	}

	.prototype-nav__arrow {
		display: grid;
		place-items: center;
		width: 44px;
		height: 44px;
		border-radius: 999px;
		border: 1px solid rgba(124, 232, 194, 0.18);
		background: rgba(255, 255, 255, 0.04);
		font-size: 1.15rem;
		transition: transform 160ms ease, background 160ms ease;
	}

	.prototype-nav__arrow:hover {
		transform: translateY(-1px);
		background: rgba(255, 255, 255, 0.08);
	}

	.prototype-nav__label {
		display: grid;
		place-items: center;
		min-width: 0;
		padding: 0 12px;
		text-align: center;
	}

	.prototype-nav__label strong {
		display: block;
		font-size: 0.8rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(233, 255, 245, 0.62);
	}

	.prototype-nav__label span {
		display: block;
		font-size: 0.95rem;
		line-height: 1.15;
		color: #effff8;
	}

	@media (max-width: 720px) {
		.prototype-nav {
			width: calc(100% - 16px);
			bottom: 12px;
		}

		.prototype-nav__label {
			padding: 0 8px;
		}

		.prototype-nav__label strong {
			font-size: 0.72rem;
		}

		.prototype-nav__label span {
			font-size: 0.88rem;
		}
	}
</style>
