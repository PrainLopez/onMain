---
import { encodeCode128C } from "../lib/code128c";

interface Props {
  value: string;
  height?: number;
  moduleWidth?: number;
  color?: string;
  showText?: boolean;
  label?: string;
}

const {
  value,
  height = 44,
  moduleWidth = 1.6,
  color = "currentColor",
  showText,
  label
} = Astro.props;

void showText;
void label;

const QUIET_ZONE_MODULES = 10;
const moduleStream = encodeCode128C(value);
const totalModules = moduleStream.length + 2 * QUIET_ZONE_MODULES;
const totalWidth = totalModules * moduleWidth;
const leftOffset = QUIET_ZONE_MODULES * moduleWidth;
---

<svg
  class="barcode-svg"
  role="img"
  aria-label={`barcode of ${value}`}
  viewBox={`0 0 ${totalWidth} ${height}`}
  preserveAspectRatio="none"
  xmlns="http://www.w3.org/2000/svg"
>
  {
    [...moduleStream].map((bit, i) =>
      bit === "1" ? (
        <rect
          x={leftOffset + i * moduleWidth}
          y="0"
          width={moduleWidth}
          height={height}
          fill={color}
        />
      ) : null
    )
  }
</svg>

<style>
  .barcode-svg {
    display: block;
    width: 100%;
    height: 44px;
  }
</style>