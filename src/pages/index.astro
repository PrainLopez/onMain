---
import BaseHead from "../components/BaseHead.astro";
import SessionPanel from "../components/SessionPanel.astro";
import { sessions } from "../data/sessions";

const latest = sessions.reduce((acc, s) => (s.date > acc.date ? s : acc));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title="on_main / 开发者技术沙龙"
      description="on_main 是一个虚拟开发者技术沙龙"
    />
  </head>
  <body class="prototype-label">
    <main class="label-shell">
      <aside class="spine" aria-label="spine">
        <div class="spine-accent-bar" aria-hidden="true"></div>
        <div class="spine-top">
          <p class="eyebrow mono">Virtual Developer Meetup</p>
        </div>
        <div class="spine-title mono">on_main</div>
        <p class="spine-foot mono">
          <span class="label-tag mono accent-green">: {latest.branch}</span>
          <br />
          <span class="label-tag mono accent-amber">@ {latest.hash}</span>
          <br />
          <span class="label-tag mono accent-violet"
            >/ rec {String(latest.record).padStart(2, "0")}</span
          >
        </p>
      </aside>

      <div class="panel-stack">
        {sessions.map((s) => <SessionPanel session={s} />)}
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #050a0d;
    --line: rgba(255, 255, 255, 0.08);
    --text: #eef7f1;
    --text-dim: rgba(238, 247, 241, 0.74);
    --text-mute: rgba(238, 247, 241, 0.5);
    --spine-bg: linear-gradient(180deg, #0c2e25 0%, #1a6b54 100%);
    --spine-accent: #2ecc40;
    --spine-text: #e8fff4;
    --spine-text-dim: rgba(232, 255, 244, 0.72);
    --font-cn:
      "Noto Sans SC Variable", "Noto Sans SC", -apple-system, "PingFang SC",
      "Microsoft YaHei", sans-serif;
    --font-ui:
      "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI",
      sans-serif;
    --font-mono:
      "Space Mono", ui-monospace, "JetBrains Mono", "SF Mono", Menlo, Consolas,
      monospace;
  }

  :global(body.prototype-label) {
    margin: 0;
    color: var(--text);
    background: var(--bg);
    overflow-x: hidden;
    font-family: var(--font-cn);
  }

  :global(body.prototype-label) main {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
  }

  .label-shell {
    width: 100%;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 0;
    align-items: stretch;
  }

  /* === spine ============================================== */
  .spine {
    position: sticky;
    top: 0;
    height: 90vh;
    padding: 22px 18px 22px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--spine-bg);
    color: var(--spine-text);
    box-shadow: inset -1px 0 0 rgba(0, 0, 0, 0.25);
  }

  .spine-accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--spine-accent);
  }

  .spine-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 8px;
  }

  .spine-title {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: clamp(3.2rem, 13vw, 6.5rem);
    line-height: 0.86;
    letter-spacing: -0.12em;
    color: var(--spine-text);
    margin: 1rem 0;
  }

  .spine-foot {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--spine-text);
    line-height: 2;
  }

  .spine-foot .sep {
    display: inline-block;
    width: 1ch;
    color: var(--spine-text-dim);
    font-weight: 600;
  }

  /* === panel-stack ======================================== */
  .panel-stack {
    padding: clamp(20px, 3vw, 32px);

    display: flex;
    flex-direction: column;
    gap: clamp(20px, 3vw, 32px);
    border-top: 1px solid var(--line);
  }

  /* === responsive ========================================= */
  @media (min-width: 1080px) {
    .panel-stack {
      padding-right: 10vw;
    }
    .spine {
      padding-left: 5vw;
    }
  }
  @media (max-width: 720px) {
    .label-shell {
      grid-template-columns: 1fr;
    }
    .spine {
      position: relative;
      top: 0;
      z-index: 10;
      height: auto;
      width: 100%;
      padding: 14px 16px 12px;
      flex-direction: row;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }
    .spine-accent-bar {
      height: 3px;
    }
    .spine-title {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: clamp(1.6rem, 8vw, 2.4rem);
      margin: 0;
      flex: 1;
    }
    .spine-foot {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      row-gap: 4px;
      column-gap: 6px;
      min-width: 0;
      max-width: 100%;
    }
    .spine-foot br {
      display: none;
    }
    .spine-foot .label-tag {
      white-space: nowrap;
    }

    .spine-foot {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
