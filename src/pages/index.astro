---
// Prototype entry: jump into the route-based `indexes` variants.
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title="on_main"
			description="开发者技术分享会的宣传页原型入口，进入 /indexes 查看三个路由版方案。"
		/>
	</head>
	<body class="entry-page">
		<main class="entry-shell">
			<p class="eyebrow">prototype entry</p>
			<h1>on_main</h1>
			<p class="lede">
				CLI prompt 风格的技术分享会宣传页。实际对比方案请去 <code>/indexes</code>，那里有三条独立路由可直接切换。
			</p>
			<a class="button" href="/indexes">open /indexes</a>
		</main>
	</body>
</html>

<style>
	:global(body.entry-page) {
		margin: 0;
		min-height: 100vh;
		display: grid;
		place-items: center;
		color: #ecfff5;
		background:
			radial-gradient(circle at 20% 18%, rgba(124, 232, 194, 0.14), transparent 24%),
			radial-gradient(circle at 82% 18%, rgba(103, 232, 249, 0.12), transparent 20%),
			linear-gradient(180deg, #071017 0%, #030608 100%);
	}

	.entry-shell {
		width: min(860px, calc(100% - 28px));
		padding: clamp(28px, 5vw, 52px);
		border-radius: 32px;
		border: 1px solid rgba(124, 232, 194, 0.16);
		background: rgba(4, 10, 14, 0.74);
		backdrop-filter: blur(18px);
		box-shadow: 0 22px 70px rgba(0, 0, 0, 0.42);
	}

	.eyebrow {
		margin: 0 0 16px;
		font-size: 0.78rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(233, 255, 245, 0.6);
	}

	h1 {
		margin: 0;
		font-size: clamp(3rem, 12vw, 6.8rem);
		line-height: 0.92;
		letter-spacing: -0.1em;
	}

	.lede {
		max-width: 54ch;
		margin: 18px 0 0;
		font-size: 1.05rem;
		line-height: 1.8;
		color: rgba(233, 255, 245, 0.84);
	}

	code {
		padding: 2px 6px;
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.06);
		color: #7ce8c2;
	}

	.button {
		display: inline-flex;
		margin-top: 28px;
		padding: 12px 18px;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #03110b;
		background: linear-gradient(135deg, #7ce8c2, #67e8f9);
	}

	@media (max-width: 720px) {
		.entry-shell {
			width: min(100%, calc(100% - 16px));
		}
	}
</style>
