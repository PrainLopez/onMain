---
import BaseHead from "../components/BaseHead.astro";
import Barcode from "../components/Barcode.astro";
import { sessions, type Session } from "../data/sessions";

const current = sessions[0];

const specRows: Array<{
  key: keyof Pick<Session, "branch" | "hash"> | "record" | "contents";
  value: string;
  accent: string;
  span: "full" | "cell";
}> = [
  {
    key: "contents",
    value: current.topics.join(" / "),
    accent: "accent-cyan",
    span: "full"
  },
  {
    key: "branch",
    value: current.branch,
    accent: "accent-green",
    span: "cell"
  },
  {
    key: "hash",
    value: current.hash,
    accent: "accent-amber",
    span: "cell"
  },
  {
    key: "record",
    value: String(current.record).padStart(2, "0"),
    accent: "accent-violet",
    span: "cell"
  }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title="on_main / 开发者技术沙龙"
      description="on_main 是一个虚拟开发者技术沙龙"
    />
  </head>
  <body class="prototype-label">
    <main class="label-shell">
      <aside class="spine" aria-label="spine">
        <div class="spine-accent-bar" aria-hidden="true"></div>
        <div class="spine-top">
          <p class="eyebrow">Virtual Developer Meetup</p>
        </div>
        <div class="spine-title">on_main</div>
        <p class="spine-foot mono">
          <span class="sep">:</span><span class="label-tag accent-green"
            >{current.branch}</span
          >
          <br />
          <span class="sep">@</span><span class="label-tag accent-amber"
            >{current.hash}</span
          >
          <br />
          <span class="sep">/</span><span class="label-tag accent-violet"
            >record {String(current.record).padStart(2, "0")}</span
          >
        </p>
      </aside>

      <section class="label-panel">
        <div class="lead">
          <p class="eyebrow label-tag accent-green">
            record / {String(current.record).padStart(2, "0")}
          </p>
          <h1>{current.title}</h1>
          <p class="summary">{current.summary}</p>
        </div>

        <div class="sheet">
          <div class="spec-grid">
            {
              specRows.map((row) => (
                <article
                  class={row.span === "full" ? "is-contents" : undefined}
                >
                  <span class={`label-tag ${row.accent}`}>{row.key}</span>
                  <strong>{row.value}</strong>
                </article>
              ))
            }
          </div>
          <Barcode
            value={current.hash}
            height={44}
            color="#0c2e25"
            label={`${current.hash} · ${current.date}`}
          />
          <p class="caption">
            每个 hex 字符映射为 4 模块条空，扫到的就是 hash 本身，不是它的 ASCII
            渲染。
          </p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #050a0d;
    --line: rgba(255, 255, 255, 0.08);
    --text: #eef7f1;
    --text-dim: rgba(238, 247, 241, 0.74);
    --text-mute: rgba(238, 247, 241, 0.5);
    --spine-bg: linear-gradient(180deg, #0c2e25 0%, #1a6b54 100%);
    --spine-accent: #2ecc40;
    --spine-text: #e8fff4;
    --spine-text-dim: rgba(232, 255, 244, 0.72);
    --font-cn:
      "Noto Sans SC Variable", "Noto Sans SC", -apple-system, "PingFang SC",
      "Microsoft YaHei", sans-serif;
    --font-ui:
      "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI",
      sans-serif;
    --font-mono:
      "Space Mono", ui-monospace, "JetBrains Mono", "SF Mono", Menlo, Consolas,
      monospace;
  }

  :global(body.prototype-label) {
    margin: 0;
    color: var(--text);
    background: var(--bg);
    overflow-x: hidden;
    font-family: var(--font-cn);
  }

  :global(body.prototype-label) main {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
  }

  .label-shell {
    width: 100%;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 0;
    align-items: stretch;
  }

  /* === spine ============================================== */
  .spine {
    position: sticky;
    top: 0;
    height: 90vh;
    padding: 22px 18px 22px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--spine-bg);
    color: var(--spine-text);
    box-shadow: inset -1px 0 0 rgba(0, 0, 0, 0.25);
  }

  .spine-accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--spine-accent);
  }

  .spine-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 8px;
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--spine-text);
  }

  .spine-title {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-mono);
    font-size: clamp(3.2rem, 13vw, 6.5rem);
    line-height: 0.86;
    letter-spacing: -0.12em;
    color: var(--spine-text);
    margin: 1rem 0;
  }

  .spine-foot {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--spine-text-dim);
    line-height: 2;
  }

  .spine-foot .sep {
    display: inline-block;
    width: 1ch;
    color: var(--spine-text-dim);
    font-weight: 600;
  }

  /* === label-panel ======================================== */
  .label-panel {
    padding: clamp(20px, 3vw, 36px);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: clamp(16px, 3vw, 32px);
    border-top: 1px solid var(--line);
  }

  .lead h1 {
    margin: 14px 0 0;
    font-family: var(--font-cn);
    font-weight: 800;
    font-size: clamp(2rem, 5.4vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    max-width: 16ch;
  }

  .summary {
    max-width: 52ch;
    margin: 18px 0 0;
    font-family: var(--font-cn);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-dim);
  }

  .sheet {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .spec-grid article {
    padding: 12px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.025);
  }

  .spec-grid article.is-contents {
    grid-column: 1 / -1;
  }

  .spec-grid article > span {
    display: block;
    margin-bottom: 6px;
  }

  .spec-grid article strong {
    display: block;
    font-family: var(--font-mono);
    font-weight: 700;
    line-height: 1.5;
    color: var(--text);
    word-break: break-all;
  }

  .caption {
    margin: 0;
    font-family: var(--font-cn);
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--text-dim);
  }

  /* === label tags (CLI accents) =========================== */
  .label-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    padding: 2px 1ch;
    line-height: 1.4;
  }

  .accent-green {
    background: #2ecc40;
    color: #07150a;
  }
  .accent-cyan {
    background: #00d7ff;
    color: #061015;
  }
  .accent-amber {
    background: #ffb000;
    color: #140d00;
  }
  .accent-violet {
    background: #af5eff;
    color: #100516;
  }

  .sep {
    font-family: var(--font-mono);
    font-weight: 600;
  }

  /* === responsive ========================================= */
  @media (max-width: 980px) {
    .label-shell {
      grid-template-columns: 1fr;
    }
    .spine {
      position: relative;
      top: 0;
      z-index: 10;
      height: auto;
      max-height: 100vh;
      padding: 14px 16px 12px;
      flex-direction: row;
      align-items: center;
      gap: 12px;
    }
    .spine-accent-bar {
      height: 3px;
    }
    .spine-title {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: clamp(1.6rem, 8vw, 2.4rem);
      margin: 0;
      flex: 1;
    }
    .spine-foot {
      display: none;
    }
    .label-panel {
      width: 100%;
      grid-template-columns: 1fr;
      padding: 20px 16px 40px;
    }
  }

  @media (max-width: 640px) {
    .spec-grid {
      grid-template-columns: 1fr;
    }
    .lead h1 {
      font-size: clamp(1.7rem, 9vw, 2.4rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
